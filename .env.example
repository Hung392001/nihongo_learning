# Nihongo Learning Environment Variables
# Copy this file to .env and modify as needed

# Application Environment
# Values: development, staging, production
NODE_ENV=development
VITE_APP_ENV=development

# Vite Configuration
# The base URL for the application (useful when deployed to a subdirectory)
# VITE_APP_BASE_URL=/

# API Configuration (if you add a backend)
# VITE_APP_API_URL=http://localhost:3001

# For Docker development - enables file watching polling
CHOKIDAR_USEPOLLING=true

# Application Settings
# VITE_APP_NAME=Nihongo Learning
# VITE_APP_VERSION=1.3.0
