# Asset Storage Configuration
# ============================================

# Asset Storage Type: 'r2', 's3', 'supabase', or 'local'
# Default: 'local' for development
VITE_ASSET_STORAGE_TYPE=local

# Base URL for assets in development/local mode
# This is where the app will look for GIF files
VITE_ASSET_BASE_PATH=/assets/gifs

# Cloudflare R2 Configuration
# Uncomment and set these when using Cloudflare R2
# VITE_R2_ACCOUNT_ID=your_account_id
# VITE_R2_BUCKET_NAME=nihongo-assets
# VITE_R2_PUBLIC_DOMAIN=assets.yourdomain.com
=======
# ============================================
# Asset Storage Configuration
# ============================================

# Asset Storage Type: 'r2', 's3', 'supabase', or 'local'
# Production: uses your Cloudflare R2 bucket by default
VITE_ASSET_STORAGE_TYPE=r2

# Base URL for assets in development/local mode
# This is where the app will look for GIF files
VITE_ASSET_BASE_PATH=/assets/gifs

# Cloudflare R2 Configuration (Your Production Bucket)
# Already configured to use: pub-5b960731e8a84853bb330dec843a0f02.r2.dev
VITE_R2_ACCOUNT_ID=
VITE_R2_BUCKET_NAME=kanji
VITE_R2_PUBLIC_DOMAIN=pub-5b960731e8a84853bb330dec843a0f02.r2.dev
# Copy this file to .env and modify as needed

# Application Environment
# Values: development, staging, production
NODE_ENV=development
VITE_APP_ENV=development

# Vite Configuration
# The base URL for the application (useful when deployed to a subdirectory)
# VITE_APP_BASE_URL=/

# API Configuration (if you add a backend)
# VITE_APP_API_URL=http://localhost:3001

# For Docker development - enables file watching polling
CHOKIDAR_USEPOLLING=true

# Application Settings
# VITE_APP_NAME=Nihongo Learning
# VITE_APP_VERSION=1.3.0

# ============================================
# Asset Storage Configuration
# ============================================

# Asset Storage Type: 'r2', 's3', 'supabase', or 'local'
# Default: 'local' for development
VITE_ASSET_STORAGE_TYPE=local

# Base URL for assets in development/local mode
# This is where the app will look for GIF files
VITE_ASSET_BASE_PATH=/assets/gifs

# Cloudflare R2 Configuration
# Uncomment and set these when using Cloudflare R2
# VITE_R2_ACCOUNT_ID=your_account_id
# VITE_R2_BUCKET_NAME=nihongo-assets
# VITE_R2_PUBLIC_DOMAIN=assets.yourdomain.com

# AWS S3 Configuration
# Uncomment and set these when using AWS S3
# VITE_S3_REGION=us-east-1
# VITE_S3_BUCKET_NAME=nihongo-assets
# VITE_S3_PUBLIC_DOMAIN=s3.yourdomain.com

# Supabase Storage Configuration
# Uncomment and set these when using Supabase Storage
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
# VITE_SUPABASE_BUCKET_NAME=kanji-gifs

# Optional: Remote asset manifest URL
# In production, set this to fetch asset metadata from a CDN
# VITE_ASSET_MANIFEST_URL=https://cdn.yourdomain.com/asset-manifest.json

# Optional: CDN base URL (overrides storage URLs)
# VITE_CDN_BASE_URL=https://cdn.yourdomain.com

# ============================================
# Feature Flags
# ============================================

# Enable/disable animations (useful for performance testing)
# VITE_ENABLE_ANIMATIONS=true

# Enable debug logging for asset loading
# VITE_DEBUG_ASSETS=false
