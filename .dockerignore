# Ignore files that don't need to be in the Docker image

# Git
.git
.gitignore

# Node modules
node_modules/

# Build output (will be recreated)
dist/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Local environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Test coverage
coverage/

# Dev container config
.devcontainer/

# Docker files (we copy them explicitly)
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
*.md

# TypeScript build cache
.tsbuildinfo
