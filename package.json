{
  "name": "nihongo-learning",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "description": "Interactive Japanese vocabulary flashcard learning system",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host --no-open",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "db:seed": "cd db && npm run db:seed",
    "db:migrate": "cd db && npm run db:migrate",
    "db:reset": "tsx db/reset.ts",
    "db:push": "cd db && npm run db:push",
    "start:backend": "cd server && npm start"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "drizzle-orm": "^0.45.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postgres": "^3.4.5",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
